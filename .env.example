PORT=3000
LOG_LEVEL=info
# Absolute or relative path to the folder containing the provided JSON data files.
# Default: sibling of this repo (../ from financial_advisor_agent/)
DATA_DIR=../

# Phase 3 — Google Gemini (optional; template briefing is used if unset)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# If set, only these emails may run `npm run cli -- advise ...` (and use Gemini). Empty = no CLI/LLM allowlist.
# ADVISE_LLM_ALLOWLIST=alice@co.com,bob@co.com
# When the list is set, pass your address on the CLI (--as) or on each API request (X-Adviser-User-Email or ?userEmail=). ADVISE_USER_EMAIL is used when the list is empty.
# ADVISE_USER_EMAIL=alice@co.com

# Phase 4 — Langfuse (optional; traces only when both keys are set; LLM run logs generation + token usage)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# CLI `advise` — optional Redis rate limit (default: off; needs local redis when enabled)
# RATE_LIMIT_CLI_ENABLED=true
# RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379
# RATE_LIMIT_CLI_POINTS=30
# RATE_LIMIT_CLI_DURATION_SEC=3600
# RATE_LIMIT_CLI_USER_KEY=you@example.com
