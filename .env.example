PORT=3000
LOG_LEVEL=info
# Absolute or relative path to the folder containing the provided JSON data files.
# Default: sibling of this repo (../ from financial_advisor_agent/)
DATA_DIR=../

# Phase 3 — Google Gemini (optional; template briefing is used if unset)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# Phase 4 — Langfuse (optional; traces only when both keys are set; LLM run logs generation + token usage)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
